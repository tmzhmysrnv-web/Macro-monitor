# Copy this to .env.local and fill in your keys

# FRED API (free at https://fred.stlouisfed.org/docs/api/api_key.html)
FRED_API_KEY=your_fred_api_key_here

# Cloudflare Turnstile (CAPTCHA) for the subscribe endpoint. When the secret is
# set, /api/subscribe requires a valid token; leave unset to rely on rate limits
# alone. Create a free widget at Cloudflare → Turnstile.
TURNSTILE_SECRET_KEY=your_turnstile_secret
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your_turnstile_site_key

# Resend for email alerts (free at https://resend.com)
RESEND_API_KEY=your_resend_api_key_here
ALERT_EMAIL_FROM=alerts@yourdomain.com

# Upstash Redis — stores subscribers, alert dedup state, and the in-app feed.
# Free tier; provision via the Vercel marketplace (Storage → Upstash Redis).
# The code also accepts Vercel's KV_REST_API_URL / KV_REST_API_TOKEN names,
# which that integration injects automatically — so on Vercel you usually don't
# need to set these two by hand.
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_rest_token

# Public site URL — used in confirm / unsubscribe / "open dashboard" links.
SITE_URL=https://your-site.vercel.app

# Cron secret — make up any random string, add to Vercel env vars too
CRON_SECRET=your_random_secret_here
