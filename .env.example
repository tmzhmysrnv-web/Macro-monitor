# Copy this to .env.local and fill in your keys

# FRED API (free at https://fred.stlouisfed.org/docs/api/api_key.html)
FRED_API_KEY=your_fred_api_key_here

# Anthropic API — powers the "Is the World Breaking?" daily summary
# (https://console.anthropic.com). Optional: the dashboard works without it,
# the summary just shows "unavailable".
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Resend for email alerts (free at https://resend.com)
RESEND_API_KEY=your_resend_api_key_here
ALERT_EMAIL_TO=you@example.com
ALERT_EMAIL_FROM=alerts@yourdomain.com

# Twilio for SMS alerts (https://twilio.com)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_NUMBER=+1xxxxxxxxxx
ALERT_SMS_TO=+1xxxxxxxxxx

# Cron secret — make up any random string, add to Vercel env vars too
CRON_SECRET=your_random_secret_here
